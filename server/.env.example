PORT=5000
NODE_ENV=development

# Set to "mongo" to use MongoDB, or "mock" to use in-memory data (default)
DATA_SOURCE=mock

# Only needed when DATA_SOURCE=mongo
MONGO_URI=mongodb://localhost:27017/bride_store

JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

CLIENT_ORIGIN=https://swastik-creations-catlog.vercel.app/
